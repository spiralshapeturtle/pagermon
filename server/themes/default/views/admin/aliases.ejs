<!DOCTYPE html>
<html lang="en">
<%- include ('../global/header') -%>
</head>
<body id="admin-body">
  <%- include ('../global/menu') -%>
  <div id="content" class="container" x-data="aliasesComponent()">
    <div class="loading" x-show="loading" x-cloak><i class="fa fa-spinner fa-spin"></i></div>
    <div class="alert alert-dismissible alert-fixed fade show"
         :class="message ? message.type : ''"
         x-show="!!message" x-cloak>
      <button type="button" class="btn-close" @click="message = null"></button>
      <strong x-text="message ? message.text : ''"></strong>
    </div>
    <div class="row" style="padding-top: 10px">
      <div class="col-sm-6 col-12">
        <h4 style="padding-left: 15px;"><a href="/admin/">Admin</a> / Aliases</h4>
      </div>
      <div class="col-12">
        <hr />
        <div class="input-group">
          <span class="input-group-text"><i class="fa fa-filter"></i></span>
          <input id="search" type="text" class="form-control" placeholder="Filter by address, alias or agency" x-model="search" @input="debounceSearch()">
          <span class="input-group-text">per page</span>
          <select class="form-select" style="width: auto; flex: 0 0 auto;" x-model.number="pageSize" @change="pageSizeChanged()">
            <option :value="25">25</option>
            <option :value="50">50</option>
            <option :value="100">100</option>
            <option :value="200">200</option>
            <option :value="-1">All</option>
          </select>
        </div>
      </div>
    </div>
    <div class="row">
      <div class="col-12">
        <p></p>
        <table class="table table-sm table-hover table-striped valign alias-table">
          <thead>
            <tr>
              <th><input class="form-check-input" type="checkbox" @change="toggleSelectAll($event.target.checked)" :checked="allSelected()" title="Select all on this page"/></th><th>ID</th><th>Address</th><th>Color</th><th>Icon</th><th>Agency</th><th>Filter</th><th>Alias</th><th></th>
            </tr>
          </thead>
          <tbody>
            <template x-for="alias in aliases" :key="alias.id">
              <tr>
                <td class="shrink"><input class="form-check-input" x-model="alias.selected" type="checkbox"/></td>
                <td class="shrink clickable-td" @click="aliasDetail(alias.id)"><span class="alias-mono" x-text="alias.id"></span></td>
                <td class="shrink clickable-td" @click="aliasDetail(alias.id)"><span class="alias-mono" x-text="alias.address"></span></td>
                <td class="shrink alias-color-cell" :style="'background-color:' + (alias.color || 'transparent')">
                  <span :style="'color:' + (alias.color ? 'white' : 'black')" x-text="alias.color"></span>
                </td>
                <td class="shrink">
                  <span x-show="alias.icon" class="fa-stack alias-icon-stack" :style="'color:' + (alias.color || 'transparent')">
                    <i class="fa fa-circle fa-stack-2x"></i>
                    <i class="fa fa-stack-1x fa-inverse" :class="'fa-' + (alias.icon || '')"></i>
                  </span>
                </td>
                <td class="shrink" x-text="alias.agency || ''"></td>
                <td class="shrink">
                  <i class="fa fa-circle text-success" x-show="alias.ignore == 0"></i>
                  <i class="fa fa-exclamation-circle text-danger" x-show="alias.ignore == 1"></i>
                </td>
                <td class="expand clickable-td" @click="aliasDetail(alias.id)" style="color: var(--accent-red);" x-text="alias.alias || ''"></td>
                <td class="shrink clickable-td" @click="aliasMessages(alias.id)"><i class="fa fa-filter"></i></td>
              </tr>
            </template>
          </tbody>
        </table>
        <div class="row" style="margin-top: 8px;">
          <div class="col-12 text-center">
            <small class="text-muted"><span x-text="totalItems"></span> aliases totaal<span x-show="totalPages > 1"> &mdash; pagina <span x-text="currentPage"></span> van <span x-text="totalPages"></span></span></small>
            <ul class="pagination" x-show="totalPages > 1">
              <li :class="{disabled: currentPage == 1}"><a @click.prevent="goToPage(1)">&laquo; Eerste</a></li>
              <li :class="{disabled: currentPage == 1}"><a @click.prevent="prevPage()">&lsaquo; Vorige</a></li>
              <template x-for="p in pageNumbers" :key="p">
                <li :class="{active: p == currentPage}"><a @click.prevent="goToPage(p)" x-text="p"></a></li>
              </template>
              <li :class="{disabled: currentPage == totalPages}"><a @click.prevent="nextPage()">Volgende &rsaquo;</a></li>
              <li :class="{disabled: currentPage == totalPages}"><a @click.prevent="goToPage(totalPages)">Laatste &raquo;</a></li>
            </ul>
            <div x-show="totalPages > 9" class="alias-goto">
              <span>Ga naar pagina</span>
              <input type="number" :min="1" :max="totalPages" x-model.number="gotoPage" @keyup.enter="jumpToPage()">
              <button class="btn btn-warning btn-sm" @click="jumpToPage()"><i class="fa fa-arrow-right"></i></button>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="btn-group-vertical" id="buttons-functions">
      <button type="button" @click="aliasImport()" class="btn btn-success">Import Aliases</button>
      <button type="button" @click="aliasExport()" class="btn btn-success">Export Aliases</button>
    </div>
    <div class="btn-group-vertical" id="buttons-management">
      <button type="button" :disabled="!aliasSelected()" @click="openBulkUpdateModal()" class="btn btn-warning">Update Selected (<span x-text="aliasSelected()"></span>)</button>
      <button type="button" :disabled="!aliasSelected()" @click="openDeleteModal()" class="btn btn-danger">Delete Selected</button>
      <button x-show="aliasRefreshRequired == 1" type="button" @click="aliasRefresh()" class="btn btn-warning">Refresh Aliases</button>
      <button class="btn btn-success" @click="aliasDetail('new')" type="button">Add New</button>
    </div>

    <!-- Delete confirmation modal -->
    <div class="modal fade" id="deleteAliasesModal" tabindex="-1" aria-modal="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header"><h5 class="modal-title">Delete aliases</h5></div>
          <div class="modal-body">
            <p>Are you sure you want to delete these aliases?</p>
            <p>Aliases cannot be restored after saving.</p>
            <p><strong><span x-text="aliasSelected()"></span> aliases selected for deletion.</strong></p>
          </div>
          <div class="modal-footer">
            <button class="btn btn-danger" @click="aliasDeleteConfirmed()">OK</button>
            <button class="btn btn-primary" data-bs-dismiss="modal">Cancel</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Bulk update modal -->
    <div class="modal fade" id="bulkUpdateAliasesModal" tabindex="-1" aria-modal="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header"><h5 class="modal-title">Update <span x-text="aliasSelected()"></span> selected aliases</h5></div>
          <div class="modal-body">
            <p class="text-muted">Kies welke velden je wilt wijzigen. Alleen aangevinkte velden worden toegepast.</p>
            <div class="mb-3 border rounded p-3">
              <div class="form-check form-switch mb-2">
                <input class="form-check-input" type="checkbox" id="bulkEnableIgnore" x-model="bulkUpdate.enableIgnore">
                <label class="form-check-label fw-bold" for="bulkEnableIgnore">Wijzig "Ignore messages"</label>
              </div>
              <div class="ms-4" x-show="bulkUpdate.enableIgnore">
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" id="bulkIgnoreVal" x-model="bulkUpdate.ignore">
                  <label class="form-check-label" for="bulkIgnoreVal">
                    <i class="fa fa-exclamation-circle text-danger"></i>
                    <strong x-text="bulkUpdate.ignore ? 'Ignore aan — berichten worden gefilterd' : 'Ignore uit — berichten worden getoond'"></strong>
                  </label>
                </div>
              </div>
            </div>
            <div class="mb-3 border rounded p-3">
              <div class="form-check form-switch mb-2">
                <input class="form-check-input" type="checkbox" id="bulkEnableAuth" x-model="bulkUpdate.enableOnlyShowLoggedIn">
                <label class="form-check-label fw-bold" for="bulkEnableAuth">Wijzig "Show only for logged-in users"</label>
              </div>
              <div class="ms-4" x-show="bulkUpdate.enableOnlyShowLoggedIn">
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" id="bulkAuthVal" x-model="bulkUpdate.onlyShowLoggedIn">
                  <label class="form-check-label" for="bulkAuthVal">
                    <i class="fa fa-lock text-warning"></i>
                    <strong x-text="bulkUpdate.onlyShowLoggedIn ? 'Aan — alleen zichtbaar voor ingelogde gebruikers' : 'Uit — ook zichtbaar voor anonieme gebruikers'"></strong>
                  </label>
                </div>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button class="btn btn-warning" @click="aliasBulkUpdateConfirmed()" :disabled="!bulkUpdate.enableIgnore && !bulkUpdate.enableOnlyShowLoggedIn">Toepassen</button>
            <button class="btn btn-secondary" data-bs-dismiss="modal">Annuleren</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Import modal -->
    <div class="modal fade" id="importAliasesModal" tabindex="-1" aria-modal="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header"><h5 class="modal-title">Import Aliases</h5></div>
          <div class="modal-body">
            <p><input type="file" id="importcsv" accept=".csv"/></p>
            <p>CSV file to be imported</p>
            <p>Available Columns: address, alias, agency, color, icon, ignore, pluginconf</p>
            <p>Required columns are "address" and "alias", all others are optional.</p>
            <div class="form-check mt-2">
              <input class="form-check-input" type="checkbox" id="importDeleteAll">
              <label class="form-check-label text-danger fw-bold" for="importDeleteAll">
                Delete all existing capcodes before import
              </label>
            </div>
          </div>
          <div class="modal-footer">
            <button class="btn btn-success" @click="aliasImportConfirmed()">Import</button>
            <button class="btn btn-danger" data-bs-dismiss="modal">Cancel</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Import results modal -->
    <div class="modal fade" id="importResultsModal" tabindex="-1" aria-modal="true">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" x-text="importResultsTitle"></h5>
            <button class="btn btn-success ms-3" data-bs-dismiss="modal" @click="afterImport()">OK</button>
          </div>
          <div class="modal-body">
            <table class="table table-striped" x-show="importResults.length > 0">
              <thead><tr><th>Address</th><th>Alias</th><th>Result</th></tr></thead>
              <tbody>
                <template x-for="(result, i) in importResults" :key="i">
                  <tr>
                    <td x-text="result.address"></td>
                    <td x-text="result.alias"></td>
                    <td x-text="result.result"></td>
                  </tr>
                </template>
              </tbody>
            </table>
            <p x-show="importResults.length === 0" x-text="importResultsMsg"></p>
          </div>
          <div class="modal-footer">
            <button class="btn btn-success" data-bs-dismiss="modal" @click="afterImport()">OK</button>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script defer src="/javascripts/admin/admin.js?v=6"></script>
  <%- include ('../global/footer') -%>
</body>
</html>
