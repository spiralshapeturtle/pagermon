<!DOCTYPE html>
<html lang="en">
<%- include ('../global/header') -%>
</head>
<body id="admin-body">
  <%- include ('../global/menu') -%>
  <div id="content" class="container" x-data="logsComponent()">
    <div class="row" style="padding-top: 10px;">
      <div class="col-12">
        <h4 style="padding-left: 15px;"><a href="/admin/">Admin</a> / Logs</h4>
        <hr />
        <div x-show="loading" class="loading"><i class="fa fa-spinner fa-spin"></i></div>
        <div x-show="error" class="alert alert-danger" x-text="error"></div>
        <div x-show="!loading && !error">
          <div class="row mb-2">
            <div class="col-md-6">
              <input type="text" class="form-control form-control-sm" placeholder="Zoeken in logs..." x-model="filter" />
            </div>
            <div class="col-md-6 text-end" style="line-height: 31px; font-size: 12px; color: var(--text-muted);">
              <span x-text="filteredLines().length"></span> / <span x-text="total"></span> regels (laatste 500)
            </div>
          </div>
          <pre class="log-viewer" x-text="filteredLines().join('\n')"></pre>
        </div>
      </div>
    </div>
  </div>
  <script defer src="/javascripts/admin/admin.js?v=7"></script>
  <%- include ('../global/footer') -%>
</body>
</html>
