<!DOCTYPE html>
<html lang="en">
<%- include ('../global/header') -%>
</head>
<body id="admin-body">
  <%- include ('../global/menu') -%>
  <div id="content" class="container" x-data="loginComponent()">
    <div class="loading" x-show="loading" x-cloak><i class="fa fa-spinner fa-spin"></i></div>
    <div class="alert alert-dismissible alert-fixed fade show"
         :class="message ? message.type : ''"
         x-show="!!message"
         x-cloak>
      <button type="button" class="btn-close" @click="message = null" aria-label="Close"></button>
      <strong x-text="message ? message.text : ''"></strong>
    </div>
    <div class="row" style="padding-top: 10px">
      <div class="col-12">
        <h4 style="padding-left: 15px;">Login</h4>
        <hr />
        <div class="col-12 offset-md-2 col-md-8">
          <form @submit.prevent="loginSubmit()">
            <div class="form-group">
              <label for="username" class="form-label">Username</label>
              <input class="form-control" type="text" id="username" x-model="user.username" required>
            </div>
            <div class="form-group">
              <label for="password" class="form-label">Password</label>
              <input class="form-control" type="password" id="password" x-model="user.password" required>
            </div>
            <button type="submit" class="btn btn-warning btn-lg" :disabled="loading">Login</button>
          </form>
        </div>
      </div>
    </div>
  </div>
  <script defer src="/javascripts/auth.js?v=2"></script>
  <%- include ('../global/footer') -%>
</body>
</html>
