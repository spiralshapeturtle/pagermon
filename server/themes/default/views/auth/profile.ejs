<!DOCTYPE html>
<html lang="en">
<%- include ('../global/header') -%>
</head>
<body id="admin-body">
  <%- include ('../global/menu') -%>
  <div id="content" class="container" x-data="profileComponent()">
    <div class="loading" x-show="loading" x-cloak><i class="fa fa-spinner fa-spin"></i></div>
    <div class="alert alert-dismissible alert-fixed fade show"
         :class="message ? message.type : ''"
         x-show="!!message"
         x-cloak>
      <button type="button" class="btn-close" @click="message = null" aria-label="Close"></button>
      <strong x-text="message ? message.text : ''"></strong>
    </div>
    <div class="row" style="padding-top: 10px">
      <div class="col-sm-6 col-12">
        <h4 style="padding-left: 15px;"><a href="/auth/profile"><span x-text="user.username"></span></a></h4>
        <div class="col-12">
          <hr />
          <form @submit.prevent="userSubmit()">
            <h5>User Details</h5>
            <div class="form-group">
              <label for="prof-username" class="col-4 col-sm-3 form-label col-form-label">Username</label>
              <div class="col-8 col-sm-9">
                <input class="form-control" type="text" id="prof-username" x-model="user.username" disabled>
              </div>
            </div>
            <div class="form-group" :class="!user.givenname ? 'has-error' : 'has-success'">
              <label for="prof-givenname" class="col-4 col-sm-3 form-label col-form-label">Given Name</label>
              <div class="col-8 col-sm-9">
                <input class="form-control" type="text" id="prof-givenname" x-model="user.givenname" required>
                <span class="form-text">Required</span>
              </div>
            </div>
            <div class="form-group">
              <label for="prof-surname" class="col-4 col-sm-3 form-label col-form-label">Surname</label>
              <div class="col-8 col-sm-9">
                <input class="form-control" type="text" id="prof-surname" x-model="user.surname">
              </div>
            </div>
            <div class="form-group" :class="!user.email || existingEmail ? 'has-error' : 'has-success'">
              <label for="prof-email" class="col-4 col-sm-3 form-label col-form-label">Email Address</label>
              <div class="col-8 col-sm-9">
                <input class="form-control" type="text" id="prof-email" x-model="user.email" @blur="checkEmail()" required>
                <span x-show="userLoading" class="fas fa-sync fa-spin fa-2x fa-fw ms-2" x-cloak aria-hidden="true"></span>
                <span class="form-text">Required</span>
                <span x-show="existingEmail" class="text-danger float-start" x-cloak>Email already exists! </span>
              </div>
            </div>
            <div class="btn-group-vertical" id="buttons-profile">
              <button type="submit" class="btn btn-success" :disabled="loading">Save</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
  <script defer src="/javascripts/auth.js?v=2"></script>
  <%- include ('../global/footer') -%>
</body>
</html>
