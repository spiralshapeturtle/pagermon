  <head>
    <meta charset="utf-8">
    <title><%= monitorName || 'PagerMon' %> <% if ( typeof pageTitle !== 'undefined') { %> | <%= pageTitle %> <% } %></title>
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=p2000dark01">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=p2000dark01">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=p2000dark01">
    <link rel="manifest" href="/manifest.json?v=p2000dark01">
    <link rel="mask-icon" href="/safari-pinned-tab.svg?v=p2000dark01" color="#ff0000">
    <link rel="shortcut icon" href="/favicon.ico?v=p2000dark01">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black">
    <meta name="apple-mobile-web-app-title" content="PagerMon">
    <meta name="application-name" content="PagerMon">
    <meta name="msapplication-config" content="/browserconfig.xml?v=p2000dark01">
    <meta name="theme-color" content="#13151a">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <script>(function(){
      var m = document.cookie.match(/(?:^|;\s*)theme=([^;]*)/);
      var theme = (m && m[1] === 'light') ? 'light' : 'dark';
      if (theme === 'light') {
        document.documentElement.classList.add('light-theme');
        document.documentElement.setAttribute('data-bs-theme', 'light');
      } else {
        document.documentElement.setAttribute('data-bs-theme', 'dark');
      }
      if (!m) {
        var e = new Date(); e.setDate(e.getDate() + 365);
        document.cookie = 'theme=dark;expires=' + e.toUTCString() + ';path=/';
      }
    })();</script>
    <!-- Self-hosted fonts (Inter) -->
    <link rel="stylesheet" href="/vendor/fonts/inter.css?v=local2">
    <!-- Self-hosted libraries (no external CDN dependency) -->
    <link rel="stylesheet" href="/vendor/bootstrap/bootstrap.min.css?v=local2">
    <link rel='stylesheet' href='/stylesheets/style.css?v=20260616d' />
    <script defer src="/vendor/bootstrap/bootstrap.bundle.min.js?v=local2"></script>
    <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css?v=local2">
    <% var safeGaCode = (typeof gaTrackingCode === 'string' && /^[A-Z0-9\-]+$/i.test(gaTrackingCode)) ? gaTrackingCode : ''; %>
    <% if (gaEnable && safeGaCode) { %>
    <!-- Global site tag (gtag.js) - Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=<%= safeGaCode %>"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', '<%= safeGaCode %>');
    </script>
      <% } %>
