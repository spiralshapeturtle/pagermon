# --- Senior Optimized .gitignore for PagerMon ---

# Dependencies
node_modules/
package-lock.json

# Environment & Secrets (Crucial!)
.env
.env.*
server/config/config.json
server/config/backup.json
server/config/vacuum_state.json

# Keep the example/default config but never the active one
!server/config/config.json.example
!server/config/default.json

# Databases
*.db
*.db-shm
*.db-wal
server/knex/seeds/
server/knex/migrations/*.bak

# OS & IDE
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs & Temp
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.nyc_output/
coverage/
pagermon_backup.tar.gz

# --- END .gitignore ---
